  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "start:android": "expo start --android",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest --watchAll",
    "test:ci": "jest --ci --watchAll=false",
    "e2e:android": "maestro test .maestro",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "jest": {
    "preset": "jest-expo",
    "moduleNameMapper": {
      "\\.css$": "<rootDir>/jest/style-mock.js"
    }
  },
  "private": true
